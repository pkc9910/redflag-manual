# Alpha Vantage — market cap data.
# Free tier: 25 req/day. Get a key at https://www.alphavantage.co/support/#api-key
# If unset, market cap renders as "Ikke tilgængelig".
ALPHA_VANTAGE_API_KEY=

# MarketScreener scraper User-Agent override (optional).
# Leave unset to use the default.
# MARKETSCREENER_USER_AGENT=

# Claude Code CLI overrides (local dev only — unused in the routine environment).
# CLAUDE_CLI_PATH=
# CLAUDE_CLI_MODEL=sonnet
